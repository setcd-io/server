{
  "name": "@setcd-io/server",
  "version": "3.5.0-29",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20",
    "yarn": ">=1.22.0",
    "npm": "please-use-yarn"
  },
  "engineStrict": true,
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/server.ts",
    "build": "yarn build:server",
    "build:server": "tsup src/server.ts --sourcemap --dts --format cjs --target esnext --cjsInterop",
    "build:exe": "yarn build && pkg dist/server.js --compress Brotli --output dist/server --targets node22-linuxstatic-x64,node22-linuxstatic-arm64",
    "start:server": "node dist/server.js",
    "start": "yarn build && node dist/server.js",
    "start:dev": "tsx src/server.ts",
    "test": "mocha 'src/**/*.test.ts' --require ts-node/register --timeout 10000"
  },
  "keywords": [],
  "author": "Scaffoldly <https://github.com/scaffoldly>",
  "license": "SEE LICENSE IN LICENSE.md",
  "description": "",
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.840.0",
    "@aws-sdk/lib-dynamodb": "3.x",
    "@bufbuild/protobuf": "^2.2.0",
    "@connectrpc/connect": "^2.0.0",
    "@connectrpc/connect-fastify": "^2.0.0",
    "@connectrpc/connect-node": "^2.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@setcd-io/connectrpc-etcd": "github:setcd-io/connectrpc-etcd#etcd-3.5",
    "@types/aws-lambda": "^8.10.147",
    "@types/blocked-at": "^1.0.4",
    "@types/bn.js": "^5.1.6",
    "@types/chai": "^5.2.2",
    "@types/lodash": "^4.17.15",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.7",
    "@types/promise-retry": "^1.1.6",
    "@types/stream-buffers": "^3.0.7",
    "@yao-pkg/pkg": "^6.4.1",
    "axios": "~1.7",
    "axios-http2-adapter": "^1.0.2",
    "blocked-at": "^1.2.0",
    "bn.js": "^5.2.2",
    "chai": "^5.2.0",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "cloudrx": "^0.1.0-beta.20250803193836.7ca97fd",
    "ddb-table": "^2.1.2",
    "dotenv": "^16.4.7",
    "dotenv-expand": "^12.0.1",
    "etcd3": "^1.1.2",
    "execa": "^9.6.0",
    "fastify": "^5.2.0",
    "lodash": "^4.17.21",
    "mocha": "^11.5.0",
    "nanoid": "^5.1.4",
    "nodemon": "^3.1.9",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "promise-retry": "^2.0.1",
    "rxjs": "^7.8.1",
    "stream-buffers": "^3.0.3",
    "timeflake": "^0.1.1",
    "tree-model": "^1.0.7",
    "ts-node": "^10.9.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "ulid": "^2.3.0"
  },
  "scaffoldly": {
    "runtime": "node:22-alpine",
    "handler": "https://localhost:2379",
    "resources": [
      "arn::dynamodb:::table/etcd"
    ],
    "files": [
      "src/certs",
      "dist/server.js",
      "package.json"
    ],
    "scripts": {
      "install": "npm install",
      "build": "npm run build",
      "start": "node dist/server.js --no-http2"
    }
  }
}